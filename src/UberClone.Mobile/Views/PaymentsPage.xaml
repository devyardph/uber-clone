<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:UberClone.Mobile.ViewModels"
             xmlns:dtos="clr-namespace:UberClone.Shared.Dtos;assembly=UberClone.Shared"
             xmlns:ios="clr-namespace:Microsoft.Maui.Controls.PlatformConfiguration.iOSSpecific;assembly=Microsoft.Maui.Controls"
             ios:Page.UseSafeArea="True"
             x:Class="UberClone.Mobile.Views.PaymentsPage"
             x:DataType="vm:PaymentsViewModel"
             Title="{Binding Title}">

    <!-- Add form on top, list below. Keeping the form above the list means it
         stays visible above the keyboard on small phones. The list region uses
         the CollectionView's own scrolling — no nested ScrollView. -->
    <Grid RowDefinitions="Auto,*"
          Padding="{StaticResource PagePaddingHorizontal},0">

        <VerticalStackLayout Grid.Row="0"
                             Style="{StaticResource FormContainer}"
                             Spacing="{StaticResource GapSm}"
                             Padding="0,12,0,12">

            <Label Text="Add a method" FontAttributes="Bold"/>

            <Grid ColumnDefinitions="2*,1*,Auto" ColumnSpacing="{StaticResource GapSm}">
                <Entry Grid.Column="0" Text="{Binding NewBrand}" Placeholder="Brand"/>
                <Entry Grid.Column="1" Text="{Binding NewLast4}"
                       Placeholder="Last 4" Keyboard="Numeric" MaxLength="4"/>
                <Button Grid.Column="2" Text="Add" Command="{Binding AddCommand}"/>
            </Grid>

            <BoxView HeightRequest="1" Color="{StaticResource Hairline}" Margin="0,8,0,0"/>
        </VerticalStackLayout>

        <CollectionView Grid.Row="1"
                        ItemsSource="{Binding Methods}"
                        MaximumWidthRequest="{StaticResource FormMaxWidth}"
                        HorizontalOptions="Center"
                        Margin="0,8,0,{OnPlatform Default=8, iOS=24, Android=8}">
            <CollectionView.EmptyView>
                <Label Text="No payment methods yet"
                       HorizontalOptions="Center"
                       Margin="0,40,0,0"
                       TextColor="{StaticResource Muted}"/>
            </CollectionView.EmptyView>
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="dtos:PaymentMethodDto">
                    <Border Padding="14"
                            Margin="0,0,0,8"
                            StrokeShape="RoundRectangle 12"
                            Stroke="{StaticResource Hairline}"
                            StrokeThickness="1">
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                            <Label Grid.Column="0" VerticalOptions="Center">
                                <Label.FormattedText>
                                    <FormattedString>
                                        <Span Text="{Binding Brand}" FontAttributes="Bold"/>
                                        <Span Text=" •••• "/>
                                        <Span Text="{Binding Last4}"/>
                                    </FormattedString>
                                </Label.FormattedText>
                            </Label>
                            <Button Grid.Column="1"
                                    Text="Remove"
                                    BackgroundColor="Transparent"
                                    TextColor="#B91C1C"
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:PaymentsViewModel}}, Path=RemoveCommand}"
                                    CommandParameter="{Binding .}"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>
