<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:UberClone.Mobile.ViewModels"
             xmlns:dtos="clr-namespace:UberClone.Shared.Dtos;assembly=UberClone.Shared"
             x:Class="UberClone.Mobile.Views.PaymentsPage"
             x:DataType="vm:PaymentsViewModel"
             Title="{Binding Title}">
    <Grid RowDefinitions="*,Auto" Padding="16">
        <CollectionView Grid.Row="0" ItemsSource="{Binding Methods}">
            <CollectionView.EmptyView>
                <Label Text="No payment methods yet" HorizontalOptions="Center" TextColor="{StaticResource Muted}"/>
            </CollectionView.EmptyView>
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="dtos:PaymentMethodDto">
                    <Border Padding="14" Margin="0,0,0,8" StrokeShape="RoundRectangle 12"
                            Stroke="#E5E7EB" StrokeThickness="1">
                        <Grid ColumnDefinitions="*,Auto">
                            <Label Grid.Column="0">
                                <Label.FormattedText>
                                    <FormattedString>
                                        <Span Text="{Binding Brand}" FontAttributes="Bold"/>
                                        <Span Text=" •••• "/>
                                        <Span Text="{Binding Last4}"/>
                                    </FormattedString>
                                </Label.FormattedText>
                            </Label>
                            <Button Grid.Column="1" Text="Remove"
                                    BackgroundColor="Transparent" TextColor="#B91C1C"
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:PaymentsViewModel}}, Path=RemoveCommand}"
                                    CommandParameter="{Binding .}"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <VerticalStackLayout Grid.Row="1" Spacing="8">
            <Label Text="Add a method" FontAttributes="Bold"/>
            <Grid ColumnDefinitions="*,*,Auto" ColumnSpacing="8">
                <Entry Grid.Column="0" Text="{Binding NewBrand}" Placeholder="Brand"/>
                <Entry Grid.Column="1" Text="{Binding NewLast4}" Placeholder="Last 4" Keyboard="Numeric"/>
                <Button Grid.Column="2" Text="Add" Command="{Binding AddCommand}"/>
            </Grid>
        </VerticalStackLayout>
    </Grid>
</ContentPage>
