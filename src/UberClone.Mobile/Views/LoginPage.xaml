<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:UberClone.Mobile.ViewModels"
             xmlns:ios="clr-namespace:Microsoft.Maui.Controls.PlatformConfiguration.iOSSpecific;assembly=Microsoft.Maui.Controls"
             ios:Page.UseSafeArea="True"
             x:Class="UberClone.Mobile.Views.LoginPage"
             x:DataType="vm:LoginViewModel"
             Title="{Binding Title}">

    <!-- ScrollView so the form is reachable on small phones when keyboard opens.
         Inner VerticalStackLayout is capped by FormMaxWidth so it looks right on iPad / Android tablet. -->
    <ScrollView>
        <Grid Padding="{StaticResource PagePaddingHorizontal},0">
            <VerticalStackLayout Style="{StaticResource FormContainer}"
                                 VerticalOptions="Center"
                                 Padding="0,40,0,40">

                <Label Text="Uber Clone"
                       FontSize="32"
                       FontAttributes="Bold"
                       HorizontalOptions="Center"/>

                <Label Text="{Binding Title}"
                       FontSize="18"
                       TextColor="{StaticResource Muted}"
                       HorizontalOptions="Center"/>

                <Entry Text="{Binding Email}" Placeholder="Email" Keyboard="Email"/>
                <Entry Text="{Binding Password}" Placeholder="Password" IsPassword="True"/>

                <Label Text="{Binding ErrorMessage}"
                       TextColor="Red"
                       IsVisible="{Binding ErrorMessage, Converter={StaticResource StringNotEmpty}}"/>

                <Button Text="Sign in"
                        Command="{Binding LoginCommand}"
                        IsEnabled="{Binding IsBusy, Converter={StaticResource Inverse}}"/>

                <ActivityIndicator IsRunning="{Binding IsBusy}"
                                   IsVisible="{Binding IsBusy}"
                                   HorizontalOptions="Center"/>

                <Button Text="Create an account"
                        Command="{Binding GoToRegisterCommand}"
                        BackgroundColor="Transparent"
                        TextColor="{StaticResource Primary}"/>
            </VerticalStackLayout>
        </Grid>
    </ScrollView>
</ContentPage>
