<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:UberClone.Mobile.ViewModels"
             x:Class="UberClone.Mobile.Views.LoginPage"
             x:DataType="vm:LoginViewModel"
             Title="{Binding Title}">
    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="16">
            <Label Text="Uber Clone" FontSize="32" FontAttributes="Bold" Margin="0,40,0,8"/>
            <Label Text="{Binding Title}" FontSize="18" TextColor="{StaticResource Muted}"/>

            <Entry Text="{Binding Email}" Placeholder="Email" Keyboard="Email"/>
            <Entry Text="{Binding Password}" Placeholder="Password" IsPassword="True"/>

            <Label Text="{Binding ErrorMessage}" TextColor="Red" IsVisible="{Binding ErrorMessage, Converter={StaticResource StringNotEmpty}}" />

            <Button Text="Sign in" Command="{Binding LoginCommand}" IsEnabled="{Binding IsBusy, Converter={StaticResource Inverse}}"/>
            <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}"/>

            <Button Text="Create an account" Command="{Binding GoToRegisterCommand}"
                    BackgroundColor="Transparent" TextColor="{StaticResource Primary}"/>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
