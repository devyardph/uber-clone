<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:UberClone.Mobile.ViewModels"
             xmlns:maps="clr-namespace:UberClone.Mobile.Maps"
             x:Class="UberClone.Mobile.Views.DriverHomePage"
             x:DataType="vm:DriverHomeViewModel"
             Title="{Binding Title}">
    <Grid RowDefinitions="*,Auto">
        <maps:GoogleMap Grid.Row="0"
                        Center="{Binding CurrentLocation}"
                        Zoom="14"/>

        <Border Grid.Row="1" Padding="20" BackgroundColor="{StaticResource Surface}">
            <VerticalStackLayout Spacing="12">
                <Label Text="{Binding StatusText}" FontSize="18" FontAttributes="Bold"/>

                <Button Text="{Binding IsOnline, Converter={StaticResource OnlineLabel}}"
                        Command="{Binding ToggleOnlineCommand}"/>

                <!-- Incoming ride card -->
                <Border IsVisible="{Binding IncomingRide, Converter={StaticResource NotNull}}"
                        StrokeShape="RoundRectangle 12" Stroke="#10B981" StrokeThickness="2"
                        Padding="14">
                    <VerticalStackLayout Spacing="6">
                        <Label Text="🚖 New trip request" FontAttributes="Bold"/>
                        <Label Text="{Binding IncomingRide.PickupAddress, StringFormat='Pickup: {0}'}"/>
                        <Label Text="{Binding IncomingRide.DropoffAddress, StringFormat='Dropoff: {0}'}"/>
                        <Label Text="{Binding IncomingRide.Fare.Amount, StringFormat='Fare: ${0:F2}'}"/>
                        <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                            <Button Grid.Column="0" Text="Decline" Command="{Binding DeclineCommand}"
                                    BackgroundColor="#F3F4F6" TextColor="{StaticResource OnSurface}"/>
                            <Button Grid.Column="1" Text="Accept" Command="{Binding AcceptRideCommand}"
                                    BackgroundColor="{StaticResource Accent}"/>
                        </Grid>
                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>
        </Border>
    </Grid>
</ContentPage>
