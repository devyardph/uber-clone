<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:UberClone.Mobile.ViewModels"
             xmlns:ios="clr-namespace:Microsoft.Maui.Controls.PlatformConfiguration.iOSSpecific;assembly=Microsoft.Maui.Controls"
             ios:Page.UseSafeArea="True"
             x:Class="UberClone.Mobile.Views.RegisterPage"
             x:DataType="vm:RegisterViewModel"
             Title="{Binding Title}">
    <ScrollView>
        <Grid Padding="{StaticResource PagePaddingHorizontal},0">
            <VerticalStackLayout Style="{StaticResource FormContainer}"
                                 VerticalOptions="Center"
                                 Padding="0,32,0,32">

                <Label Text="{Binding Title}" FontSize="22" FontAttributes="Bold"/>
                <Entry Text="{Binding FullName}" Placeholder="Full name"/>
                <Entry Text="{Binding Email}" Placeholder="Email" Keyboard="Email"/>
                <Entry Text="{Binding Phone}" Placeholder="Phone" Keyboard="Telephone"/>
                <Entry Text="{Binding Password}" Placeholder="Password" IsPassword="True"/>

                <Label Text="{Binding ErrorMessage}"
                       TextColor="Red"
                       IsVisible="{Binding ErrorMessage, Converter={StaticResource StringNotEmpty}}"/>

                <Button Text="Create account"
                        Command="{Binding RegisterCommand}"
                        IsEnabled="{Binding IsBusy, Converter={StaticResource Inverse}}"/>

                <ActivityIndicator IsRunning="{Binding IsBusy}"
                                   IsVisible="{Binding IsBusy}"
                                   HorizontalOptions="Center"/>
            </VerticalStackLayout>
        </Grid>
    </ScrollView>
</ContentPage>
