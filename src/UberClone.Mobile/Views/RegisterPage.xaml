<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:UberClone.Mobile.ViewModels"
             x:Class="UberClone.Mobile.Views.RegisterPage"
             x:DataType="vm:RegisterViewModel"
             Title="{Binding Title}">
    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="16">
            <Label Text="{Binding Title}" FontSize="22" FontAttributes="Bold"/>
            <Entry Text="{Binding FullName}" Placeholder="Full name"/>
            <Entry Text="{Binding Email}" Placeholder="Email" Keyboard="Email"/>
            <Entry Text="{Binding Phone}" Placeholder="Phone" Keyboard="Telephone"/>
            <Entry Text="{Binding Password}" Placeholder="Password" IsPassword="True"/>
            <Label Text="{Binding ErrorMessage}" TextColor="Red"/>
            <Button Text="Create account" Command="{Binding RegisterCommand}"/>
            <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}"/>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
